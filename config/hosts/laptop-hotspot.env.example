# Copy this file to config/hosts/laptop-hotspot.local.env.
# The *.local.env files are ignored by Git and are meant for local secrets only.

LAPTOP_HOST=10.88.0.55
LAPTOP_PORT=22
LAPTOP_USER=orizon32
LAPTOP_PASSWORD=

# Optional. Leave empty if sudo is not needed for diagnostics.
LAPTOP_SUDO_PASSWORD=

# The laptop is reachable from the ZimaOS hotspot network, so scripts use
# config/hosts/zimaos.local.env as an SSH jump host by default.
LAPTOP_JUMP=zimaos
